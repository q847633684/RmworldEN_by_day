    "ignorePaths": [
        "**/__pycache__/**",
        "**/.pytest_cache/**",
        "**/node_modules/**",
        "**/.git/**",
        "**/logs/**",
        "**/test_output/**",
        "**/*.pyc",
        "**/.mypy_cache/**",
        "**/build/**",
        "**/dist/**",
        "**/*.egg-info/**"
    ],
    "overrides": [
        {
            "filename": "**/*.py",
            "languageId": "python"
        },
        {
            "filename": "**/*.md",
            "languageId": "markdown"
        },
        {
            "filename": "**/*.json",
            "languageId": "json"
        },
        {
            "filename": "**/*.jsonc",
            "languageId": "jsonc"
        }
    ],
    "patterns": [
        {
            "name": "markdown-code-blocks",
            "pattern": "/```[\\s\\S]*?```/g"
        },
        {
            "name": "inline-code",
            "pattern": "/`[^`]*`/g"
        }
    ],
    "dictionaries": [
        "en_US",
        "python",
        "softwareTerms",
        "misc"
    ],
    "dictionaryDefinitions": [
        {
            "name": "project-terms",
            "words": [
                "definjected",
                "keyed",
                "rimworld"
            ]
        }
    ]
