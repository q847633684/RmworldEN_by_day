[MASTER]
# 加载的扩展插件
load-plugins =

# 忽略的文件或目录
ignore = __pycache__,
         .git,
         .pytest_cache,
         build,
         dist,
         *.egg-info

# 忽略的文件模式
ignore-patterns = test_.*\.py,
                  .*_test\.py,
                  conftest\.py

[MESSAGES CONTROL]
# 禁用的检查项
disable =
    # 格式相关 (由black处理)
    C0103,  # invalid-name
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring

    # 设计相关 (根据项目需要调整)
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    R0915,  # too-many-statements

    # 警告相关 (常见但不重要)
    W0613,  # unused-argument
    W0622,  # redefined-builtin
    W0718,  # broad-exception-caught
    W0719,  # broad-exception-raised

    # 导入相关
    W0611,  # unused-import (由flake8处理)

    # 其他常见问题
    C0301,  # line-too-long (由black处理)
    R0902,  # too-many-instance-attributes
    R0912,  # too-many-branches
    R1705,  # no-else-return
    E1134,  # not-a-mapping (常见的dataclass误报)
    W1203,  # logging-fstring-interpolation
    C0415,  # import-outside-toplevel
    W0707,  # raise-missing-from

[FORMAT]
# 最大行长度
max-line-length = 88

# 每行最大参数数量
max-args = 8

# 每个函数最大局部变量数量
max-locals = 20

[VARIABLES]
# 允许的变量名
good-names = i,j,k,ex,_,e,f,df,fn,id,md,os,re,x,y,z,ui,api,csv,xml,url,uri,dt

# 允许的变量名模式
good-names-rgxs = ^[a-z][a-z0-9_]{0,30}$

[BASIC]
# 函数名规则
function-rgx = ^[a-z_][a-z0-9_]{2,30}$

# 方法名规则
method-rgx = ^[a-z_][a-z0-9_]{2,30}$

# 类名规则
class-rgx = ^[A-Z][a-zA-Z0-9]+$

# 常量名规则
const-rgx = ^([A-Z_][A-Z0-9_]*|__[a-z0-9_]+__)$

# 模块名规则
module-rgx = ^[a-z_][a-z0-9_]*$

[DESIGN]
# 类的最大属性数量
max-attributes = 15

# 类的最大方法数量
max-public-methods = 25

[IMPORTS]
# 已知的第三方库
known-third-party =
    colorama,
    lxml,
    openpyxl,
    xlsxwriter,
    pytest,
    dataclasses

[SIMILARITIES]
# 忽略相似代码检查的最小行数
min-similarity-lines = 10

# 忽略注释和文档字符串的相似性
ignore-comments = yes
ignore-docstrings = yes
ignore-imports = yes

[LOGGING]
# 日志格式字符串
logging-format-style = new

[REPORTS]
# 输出格式
output-format = colorized

# 是否显示报告
reports = no

# 评分显示
score = yes
