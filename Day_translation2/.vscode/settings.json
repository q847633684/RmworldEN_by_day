{
    // ========== Day_translation2 项目专用配置 ==========

    // ========== Python开发核心设置 ==========
    "python.defaultInterpreterPath": "python",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,

    // ========== 代码质量工具协作配置 ==========

    // 1. Black 格式化 (主格式化工具)
    "python.formatting.provider": "black",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.rulers": [88]
    },

    // 2. Flake8 配置 (与Black兼容)
    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Args": [
        "--ignore=E501,E402,W503,E203,F401,F841",
        "--max-line-length=88",
        "--exclude=__pycache__,.git,.pytest_cache,build,dist"
    ],

    // 3. Pylint 配置 (深度分析)
    "python.linting.pylintEnabled": true,
    "python.linting.pylintArgs": [
        "--rcfile=${workspaceFolder}/../.pylintrc",
        "--load-plugins=pylint.extensions.docparams"
    ],

    // 4. Mypy 配置 (类型检查)
    "python.linting.mypyEnabled": true,
    "python.linting.mypyArgs": [
        "--config-file=${workspaceFolder}/../mypy.ini",
        "--show-error-codes"
    ],

    // 5. 减少Pylance重复诊断 (避免与质量工具冲突)
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none",
        "reportMissingTypeStubs": "none",
        "reportUnusedImport": "information",      // 降级，让Flake8处理
        "reportUnusedVariable": "information",    // 降级，让Flake8处理
        "reportGeneralTypeIssues": "information", // 降级，让Mypy处理
        "reportOptionalMemberAccess": "none",
        "reportOptionalSubscript": "none"
    },

    // ========== 编辑器设置 ==========
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [88],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 88,

    // ========== 文件处理 ==========
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.encoding": "utf8",

    // ========== 测试配置 ==========
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "python.testing.pytestArgs": [
        "tests",
        "-v",
        "--tb=short"
    ],

    // ========== 问题面板优化 ==========
    "problems.decorations.enabled": true,
    "problems.showCurrentInStatus": true,
    "problems.sortOrder": "severity",

    // ========== 文件排除 ==========
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/build": true,
        "**/dist": true,
        "**/.mypy_cache": true
    },

    "search.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/build": true,
        "**/dist": true
    }
}
